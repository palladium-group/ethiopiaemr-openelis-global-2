    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <!-- Seed Hemax 320 hematology analyzer and test mappings -->

    <!-- Insert Hemax 320 analyzer -->
    <changeSet author="said-murad" id="012-001-insert-hemax-320-analyzer">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">
                SELECT COUNT(*) FROM clinlims.analyzer WHERE name = 'Hemax 320'
            </sqlCheck>
        </preConditions>
        <comment>Insert Hemax 320 hematology analyzer</comment>
        <insert tableName="analyzer" schemaName="clinlims">
            <column name="id" valueSequenceNext="analyzer_seq"/>
            <column name="name" value="Hemax 320"/>
            <column name="description" value="Hemax 320 Hematology Analyzer"/>
            <column name="analyzer_type_id" valueComputed="(SELECT id FROM clinlims.analyzer_type WHERE name = 'HEMATOLOGY')"/>
            <column name="status" value="SETUP"/>
            <column name="is_active" valueBoolean="true"/>
            <column name="has_setup_page" valueBoolean="false"/>
            <column name="last_updated" valueComputed="NOW()"/>
        </insert>
        <rollback>
            <delete tableName="analyzer" schemaName="clinlims">
                <where>name = 'Hemax 320'</where>
            </delete>
        </rollback>
    </changeSet>

